generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Company {
  id        String   @id @default(uuid())
  name      String
  slug      String   @unique
  logoUrl   String?
  phone     String?
  email     String?
  address   String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users       User[]
  crews       Crew[]
  jobs        Job[]
  customers   Customer[]
  properties  Property[]
  permits        Permit[]
  inspections    Inspection[]
  vendors        Vendor[]
  invoices       Invoice[]
  timeEntries    TimeEntry[]
  emailCampaigns EmailCampaign[]
}

model User {
  id        String   @id @default(uuid())
  authId    String?  @unique
  companyId String
  email     String   @unique
  name      String
  role      String   @default("crew_member")
  avatarUrl String?
  phone     String?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  company      Company       @relation(fields: [companyId], references: [id])
  crewMembers  CrewMember[]
  notes        Note[]
  activityLogs ActivityLog[]
  timeEntries  TimeEntry[]

  @@index([companyId])
  @@index([authId])
}

model Crew {
  id        String   @id @default(uuid())
  companyId String
  name      String
  color     String   @default("#3b82f6")
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  company Company      @relation(fields: [companyId], references: [id])
  members CrewMember[]
  jobs    Job[]

  @@index([companyId])
}

model CrewMember {
  id       String   @id @default(uuid())
  crewId   String
  userId   String
  role     String   @default("member")
  joinedAt DateTime @default(now())

  crew Crew @relation(fields: [crewId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([crewId, userId])
}

model Customer {
  id          String   @id @default(uuid())
  companyId   String
  name        String
  email       String?
  phone       String?
  address     String?
  portalToken String?  @unique
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  company         Company          @relation(fields: [companyId], references: [id])
  properties      Property[]
  jobs            Job[]
  messages        PortalMessage[]
  emailRecipients EmailRecipient[]

  @@index([companyId])
}

model Property {
  id         String   @id @default(uuid())
  companyId  String
  customerId String
  address    String
  city       String
  state      String
  zip        String
  lat        Float?
  lng        Float?
  notes      String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  company  Company @relation(fields: [companyId], references: [id])
  customer Customer @relation(fields: [customerId], references: [id])
  jobs     Job[]

  @@index([companyId])
  @@index([customerId])
}

model Job {
  id             String    @id @default(uuid())
  companyId      String
  customerId     String
  propertyId     String?
  crewId         String?
  jobNumber      String    @unique
  title          String
  description    String?
  type           String
  category       String?
  status         String    @default("scheduled")
  priority       String    @default("medium")
  isRecurring    Boolean   @default(false)
  scheduledDate  DateTime?
  startDate      DateTime?
  completedDate  DateTime?
  estimatedEnd   DateTime?
  estimatedHours Float?
  actualHours    Float?
  estimatedCost  Decimal?  @db.Decimal(12, 2)
  actualCost     Decimal?  @db.Decimal(12, 2)
  progress       Int       @default(0)
  address        String?
  isArchived     Boolean   @default(false)
  deletedAt      DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  company      Company       @relation(fields: [companyId], references: [id])
  customer     Customer      @relation(fields: [customerId], references: [id])
  property     Property?     @relation(fields: [propertyId], references: [id])
  crew         Crew?         @relation(fields: [crewId], references: [id])
  tasks        Task[]
  photos       Photo[]
  notes        Note[]
  permits      Permit[]
  inspections  Inspection[]
  materials    Material[]
  activityLogs ActivityLog[]
  invoices           Invoice[]
  timeEntries        TimeEntry[]
  recurringSchedule  RecurringSchedule?

  @@index([companyId])
  @@index([customerId])
  @@index([crewId])
  @@index([status])
  @@index([category])
  @@index([priority])
  @@index([scheduledDate])
}

model Task {
  id          String    @id @default(uuid())
  jobId       String
  title       String
  description String?
  status      String    @default("pending")
  sortOrder   Int       @default(0)
  dueDate     DateTime?
  completedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  job Job @relation(fields: [jobId], references: [id], onDelete: Cascade)

  @@index([jobId])
}

model Photo {
  id         String   @id @default(uuid())
  jobId      String
  url        String
  caption    String?
  category   String   @default("progress")
  uploadedBy String?
  lat        Float?
  lng        Float?
  createdAt  DateTime @default(now())

  job Job @relation(fields: [jobId], references: [id], onDelete: Cascade)

  @@index([jobId])
}

model Note {
  id        String   @id @default(uuid())
  jobId     String
  userId    String?
  content   String
  type      String   @default("general")
  createdAt DateTime @default(now())

  job  Job   @relation(fields: [jobId], references: [id], onDelete: Cascade)
  user User? @relation(fields: [userId], references: [id])

  @@index([jobId])
}

model Permit {
  id           String    @id @default(uuid())
  companyId    String
  jobId        String?
  permitNumber String?
  type         String
  status       String    @default("pending")
  jurisdiction String?
  issuedDate   DateTime?
  expiryDate   DateTime?
  cost         Decimal?  @db.Decimal(12, 2)
  notes        String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  company     Company      @relation(fields: [companyId], references: [id])
  job         Job?         @relation(fields: [jobId], references: [id])
  inspections Inspection[]

  @@index([companyId])
  @@index([jobId])
}

model Inspection {
  id            String    @id @default(uuid())
  companyId     String
  jobId         String?
  permitId      String?
  type          String
  status        String    @default("scheduled")
  scheduledDate DateTime?
  completedDate DateTime?
  inspector     String?
  result        String?
  notes         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  company Company @relation(fields: [companyId], references: [id])
  job     Job?    @relation(fields: [jobId], references: [id], onDelete: Cascade)
  permit  Permit? @relation(fields: [permitId], references: [id])

  @@index([companyId])
  @@index([jobId])
}

model Material {
  id           String    @id @default(uuid())
  jobId        String
  vendorId     String?
  name         String
  quantity     Float
  unit         String    @default("each")
  unitCost     Decimal?  @db.Decimal(12, 2)
  totalCost    Decimal?  @db.Decimal(12, 2)
  status       String    @default("needed")
  orderedDate  DateTime?
  deliveryDate        DateTime?
  deliveryConfirmedAt DateTime?
  createdAt           DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  job    Job     @relation(fields: [jobId], references: [id], onDelete: Cascade)
  vendor Vendor? @relation(fields: [vendorId], references: [id], onDelete: SetNull)

  @@index([jobId])
}

model Vendor {
  id        String   @id @default(uuid())
  companyId String
  name      String
  contact   String?
  phone     String?
  email     String?
  address   String?
  category  String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  company   Company    @relation(fields: [companyId], references: [id])
  materials Material[]

  @@index([companyId])
}

model Invoice {
  id            String    @id @default(uuid())
  companyId     String
  jobId         String
  invoiceNumber String    @unique
  status        String    @default("draft")
  subtotal      Decimal   @db.Decimal(12, 2)
  tax           Decimal   @default(0) @db.Decimal(12, 2)
  total         Decimal   @db.Decimal(12, 2)
  dueDate       DateTime?
  paidDate      DateTime?
  notes         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  company   Company            @relation(fields: [companyId], references: [id])
  job       Job                @relation(fields: [jobId], references: [id])
  lineItems InvoiceLineItem[]

  @@index([companyId])
  @@index([jobId])
  @@index([status])
}

model InvoiceLineItem {
  id          String  @id @default(uuid())
  invoiceId   String
  description String
  quantity    Float   @default(1)
  unitPrice   Decimal   @db.Decimal(12, 2)
  total       Decimal   @db.Decimal(12, 2)
  type        String  @default("service")

  invoice Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  @@index([invoiceId])
}

model ActivityLog {
  id        String   @id @default(uuid())
  jobId     String
  userId    String?
  action    String
  details   String?
  createdAt DateTime @default(now())

  job  Job   @relation(fields: [jobId], references: [id], onDelete: Cascade)
  user User? @relation(fields: [userId], references: [id])

  @@index([jobId])
}

model PortalMessage {
  id         String   @id @default(uuid())
  customerId String
  senderType String
  content    String
  isRead     Boolean  @default(false)
  readAt     DateTime?
  createdAt  DateTime @default(now())

  customer Customer @relation(fields: [customerId], references: [id])

  @@index([customerId])
}

model RecurringSchedule {
  id          String   @id @default(uuid())
  jobId       String   @unique
  frequency   String   // "weekly", "biweekly", "monthly", "quarterly"
  dayOfWeek   Int?     // 0-6 for weekly
  dayOfMonth  Int?     // 1-31 for monthly
  nextRunDate DateTime
  lastRunDate DateTime?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  job Job @relation(fields: [jobId], references: [id], onDelete: Cascade)
}

model TimeEntry {
  id        String   @id @default(uuid())
  companyId String
  jobId     String
  userId    String?
  hours     Float
  date      DateTime
  notes     String?
  billable  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  company Company @relation(fields: [companyId], references: [id])
  job     Job     @relation(fields: [jobId], references: [id], onDelete: Cascade)
  user    User?   @relation(fields: [userId], references: [id])

  @@index([companyId])
  @@index([jobId])
}

model EmailCampaign {
  id         String   @id @default(uuid())
  companyId  String
  name       String
  subject    String
  body       String
  template   String   @default("general")
  status     String   @default("draft")
  sentAt     DateTime?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  company    Company          @relation(fields: [companyId], references: [id])
  recipients EmailRecipient[]

  @@index([companyId])
}

model EmailRecipient {
  id         String   @id @default(uuid())
  campaignId String
  customerId String
  email      String
  status     String   @default("pending")
  sentAt     DateTime?
  openedAt   DateTime?
  createdAt  DateTime @default(now())

  campaign EmailCampaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  customer Customer      @relation(fields: [customerId], references: [id])

  @@index([campaignId])
}
